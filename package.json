{
  "name": "whats-next-mcp",
  "version": "0.1.0",
  "description": "An MCP server that guarantees an agent always has suggestions for what to do next — a recursive 'never a dead end' companion for Claude Code, opencode, and any MCP host.",
  "type": "module",
  "bin": {
    "whats-next-mcp": "dist/index.js",
    "whats-next-hook": "dist/hook.js",
    "whats-next-cursor-hook": "dist/cursor-hook.js",
    "whats-next": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "npm run build && node --test",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "opencode",
    "agent",
    "suggestions",
    "next-steps"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.40.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  }
}
